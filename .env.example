# ========================================
# UPLOAD CONFIGURATION
# ========================================
# Directory where uploaded files are stored inside the container
UPLOAD_DIR=/var/uploads

# ========================================
# DATABASE CONFIGURATION
# ========================================
# External PostgreSQL Server Configuration
# Replace with your actual server IP and credentials
QUARKUS_DATASOURCE_USERNAME=app
QUARKUS_DATASOURCE_PASSWORD=app
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://your-server-ip:5432/app_emendas
# Example: jdbc:postgresql://192.168.1.100:5432/app_emendas

# ========================================
# JWT CONFIGURATION
# ========================================
JWT_SECRET=changeit-changeit-changeit-changeit
JWT_EXPIRATION_SECONDS=3600

# ========================================
# EMAIL CONFIGURATION (SMTP)
# ========================================
