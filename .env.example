# ===============================================
# Environment Variables for Portal de Emendas
# ===============================================
# Copy this file to .env and configure as needed
# Docker Compose will automatically load .env file

# ===============================================
# DATABASE
# ===============================================
POSTGRES_DB=app_emendas
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# ===============================================
# JWT AUTHENTICATION
# ===============================================
# IMPORTANT: Change this secret in production!
JWT_SECRET=changeit-changeit-changeit-changeit

# ===============================================
# EXTERNAL API
# ===============================================
# Token for syncing data from external emendas API
EXTERNAL_EMENDAS_API_TOKEN=a0c466c8230dc031ea5b833c0c03983fe892ec55298f3ebe6523b320acc29c3c

# ===============================================
# MAILER CONFIGURATION
# ===============================================

# Mock mode (development): emails are logged but not sent
# Set to "false" for production to send real emails
QUARKUS_MAILER_MOCK=true

# Email sender address
QUARKUS_MAILER_FROM=noreply@portal-emendas.local

# ===============================================
# SMTP SERVER (For Production - when MOCK=false)
# ===============================================

# Option 1: Gmail
# QUARKUS_MAILER_HOST=smtp.gmail.com
# QUARKUS_MAILER_PORT=587
# QUARKUS_MAILER_START_TLS=REQUIRED
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Option 2: SendGrid
# QUARKUS_MAILER_HOST=smtp.sendgrid.net
# QUARKUS_MAILER_PORT=587
# QUARKUS_MAILER_START_TLS=REQUIRED
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=SG.xxxxxxxxxxxxx

# Option 3: AWS SES
# QUARKUS_MAILER_HOST=email-smtp.us-east-1.amazonaws.com
# QUARKUS_MAILER_PORT=587
# QUARKUS_MAILER_START_TLS=REQUIRED
# SMTP_USERNAME=AKIAXXXXXXXX
# SMTP_PASSWORD=XXXXXXXXXXXXXXX

# Option 4: Custom SMTP
# QUARKUS_MAILER_HOST=smtp.your-server.com
# QUARKUS_MAILER_PORT=587
# QUARKUS_MAILER_START_TLS=REQUIRED
# SMTP_USERNAME=your-username
# SMTP_PASSWORD=your-password

# Auth methods (usually default is fine)
# QUARKUS_MAILER_AUTH_METHODS=DIGEST-MD5 CRAM-SHA256 CRAM-SHA1 CRAM-MD5 PLAIN LOGIN

# ===============================================
# CORS (Frontend Origins)
# ===============================================
# Comma-separated list of allowed origins
# QUARKUS_HTTP_CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# ===============================================
# NOTES
# ===============================================
# 1. For Gmail: You must create an App Password
#    Go to: https://myaccount.google.com/apppasswords
#    Enable 2FA first, then generate App Password
#
# 2. For SendGrid: Get API key from SendGrid dashboard
#    Username is always "apikey"
#
# 3. For AWS SES: Use IAM credentials with SES permissions
#    Verify sender email in SES console first
#
# 4. Never commit .env file with real credentials to git!
#    Add .env to .gitignore

